rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuário lê/escreve apenas seu próprio doc /users/{uid}.
    match /users/{uid} {
      allow read, create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Empresas: leitura/escrita somente para membros da empresa.
    // O cadastro permite criar uma nova empresa colocando o próprio uid no array `members`.
    match /companies/{cid} {
      function isMember() {
        return request.auth != null && request.auth.uid in resource.data.members;
      }
      function joiningOrCreating() {
        return request.auth != null && request.auth.uid in request.resource.data.members;
      }

      allow read: if isMember();
      allow create: if joiningOrCreating();
      // Permite update se já é membro OU se está entrando no array members agora (join via código).
      allow update: if isMember() || joiningOrCreating();
      allow delete: if isMember() && request.auth.uid == resource.data.ownerUid;

      // Subcoleções (veiculos, motoristas, linhas, combustivel, manutencao,
      // finEmpresa, finPessoal, contratos, metasPessoais, settings, ...)
      // Acesso somente para membros da empresa-pai.
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/companies/$(cid)).data.members;
      }
    }
  }
}
